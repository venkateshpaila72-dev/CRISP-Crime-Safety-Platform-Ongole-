# ── MongoDB ──────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGODB_DB_NAME=ongole_safemap

# ── JWT Auth (for admin login) ──────────────────────────
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

# ── First Admin Account (used once by scripts/seed_db.py) ──
ADMIN_EMAIL=admin@ongolesafemap.local
ADMIN_PASSWORD=

# ── CORS (comma-separated list of frontend URLs allowed to call this API) ──
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Groq (tourist safety chat assistant) ────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── App Environment ─────────────────────────────────────
ENVIRONMENT=development